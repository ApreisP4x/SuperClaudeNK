      "type": "content",
      "content": "\"\"\"Base classes for SuperClaude installation system\"\"\"\n\nfrom .component import Component\nfrom .installer import Installer\n\n__all__ = ['Component', 'Installer']",
      "hash": "229f2ec14f13281bbf287922bb5e2e22ae1510e6b41f780550239075d5585679",
