      "type": "content",
      "content": "\"\"\"Component implementations for SuperClaude installation system\"\"\"\n\nfrom .core import CoreComponent\nfrom .commands import CommandsComponent\nfrom .mcp import MCPComponent\nfrom .hooks import HooksComponent\n\n__all__ = [\n    'CoreComponent',\n    'CommandsComponent', \n    'MCPComponent',\n    'HooksComponent'\n]",
