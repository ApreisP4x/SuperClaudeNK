      "type": "content",
      "content": "\"\"\"Utility modules for SuperClaude installation system\"\"\"\n\nfrom .ui import ProgressBar, Menu, confirm, Colors\nfrom .logger import Logger\nfrom .security import SecurityValidator\n\n__all__ = [\n    'ProgressBar',\n    'Menu', \n    'confirm',\n    'Colors',\n    'Logger',\n    'SecurityValidator'\n]",
